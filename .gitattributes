# Normalize line endings: store everything as LF in the repository.
* text=auto eol=lf

# Explicit text files
*.py    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.svg   text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binary assets — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
